{
  "name": "projeto-arca",
  "version": "0.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev:server": "nodemon --watch . -e js src/server.js",
    "dev:watch": "browser-sync start --proxy localhost:3001 --no-notify --files 'src/**/*.ejs, public/**/*.css, public/**/*.js'",
    "dev": "npm-run-all --parallel dev:server dev:watch"
  },
  "dependencies": {
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "node": "^24.16.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5"
  }
}
