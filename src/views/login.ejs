<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('partials/head', { title: 'Entrar | ARCA' }) %>
</head>
<body class="login-page">
    <%- include('partials/header', { activePage: 'login' }) %>

    <main class="login-shell">
        <a class="back-link" href="/home">
            <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
            Voltar
        </a>

        <section class="login-card" aria-labelledby="login-title">
            <div class="login-brand-icon" aria-hidden="true">
                <span class="material-symbols-outlined">pets</span>
            </div>

            <header class="login-card-header">
                <h1 id="login-title">Entrar</h1>
                <p>Acesse sua conta para acompanhar adoções, resgates e serviços.</p>
            </header>

            <form class="login-form" action="/login" method="post">
                <% if (typeof authError !== 'undefined' && authError) { %>
                    <p class="form-error" role="alert"><%= authError %></p>
                <% } %>

                <div class="form-group">
                    <label for="usuario">Usuário</label>
                    <div class="input-control">
                        <span class="material-symbols-outlined" aria-hidden="true">person</span>
                        <input id="usuario" name="usuario" type="text" autocomplete="username" placeholder="tutor, candidato, ong ou prefeitura" value="<%= typeof loginUsername !== 'undefined' ? loginUsername : '' %>" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="senha">Senha</label>
                    <div class="input-control input-control-password">
                        <span class="material-symbols-outlined" aria-hidden="true">lock</span>
                        <input id="senha" name="senha" type="password" autocomplete="current-password" placeholder="••••••••" required>
                        <button class="password-toggle" type="button">
                            <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
                            Mostrar senha
                        </button>
                    </div>
                </div>

                <div class="form-row">
                    <label class="remember-control" for="lembrar">
                        <input id="lembrar" name="lembrar" type="checkbox" checked>
                        <span class="checkbox-visual" aria-hidden="true">
                            <span class="material-symbols-outlined">check</span>
                        </span>
                        Lembrar de mim
                    </label>
                    <a class="forgot-link" href="/recuperar-senha">Esqueci minha senha</a>
                </div>

                <button class="login-primary-button" type="submit">Entrar</button>

                <div class="login-divider" aria-hidden="true">
                    <span></span>
                    <small>ou</small>
                    <span></span>
                </div>

                <a class="login-secondary-button" href="/cadastro">Criar conta</a>
            </form>
        </section>
    </main>
</body>
</html>
