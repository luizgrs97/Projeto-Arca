<!DOCTYPE html>
<html lang="pt-br">

<head>
    <%- include('partials/head', { title: 'ARCA' }) %>
        <link rel="stylesheet" href="/assets/css/resgatar.css">
</head>

<body class="home-page">
    <%- include('partials/header', { activePage: 'home' }) %>
        <div id="pagina">
            <a href="/home">
                <p id="voltar">&larr; Voltar</p>
            </a>
            <h1>Resgatar Animal</h1>
            <p class="sub">Descreva a situação do animal que precisa de resgate...</p>

            <div id="grid">

                <div class="card">
                    <p class="card-titulo"><span class="material-symbols-outlined">location_on</span> Localização do
                        animal</p>
                    <div class="area-mapa"></div>
                    <button class="btn-verde"><span class="material-symbols-outlined">location_on</span> Selecionar
                        localização</button>
                </div>

                <div class="card">
                    <p class="card-titulo"><span class="material-symbols-outlined">Image
                        </span> Imagem do
                        animal</p>
                    <label class="animal-upload" for="imagem-animal">
                        <input id="imagem-animal" name="imagemAnimal" type="file" accept="image/png,image/jpeg"
                            required>
                        <span class="material-symbols-outlined">add_photo_alternate</span>
                        <strong>Envie uma imagem do animal<span class="required-mark">*</span></strong>
                        <small>Formatos aceitos: JPG, PNG. Máx. 5MB.</small>
                    </label>
                </div>

                <div class="card">
                    <p class="card-titulo"><span class="material-symbols-outlined">calendar_month</span> Descrição</p>
                    <p class="desc-sub">Descreva a situação do animal ferido e seu estado de saúde.</p>
                    <textarea placeholder="Escreva aqui..."></textarea>
                    <div class="declaracao">
                        <input type="checkbox" id="declaracao">
                        <label for="declaracao">Declaro que as informações fornecidas são verídicas</label>
                    </div>
                </div>

                <div class="card">
                    <p class="card-titulo"><span class="material-symbols-outlined">person</span> Seus dados de contato
                    </p>
                    <label for="nome">Nome</label>
                    <input type="text" id="nome" placeholder="Seu nome completo">
                    <label for="email">E-mail</label>
                    <input type="email" id="email" placeholder="seu@email.com">
                    <label for="tel">Telefone</label>
                    <input type="tel" id="tel" placeholder="(11) 99999-9999">
                </div>

            </div>

            <div id="rodape">
                <button class="btn-cancelar"><span class="material-symbols-outlined">close</span> Cancelar</button>
                <button class="btn-verde"><span class="material-symbols-outlined">pets</span> Solicitar resgate</button>
            </div>
        </div>
</body>

</html>